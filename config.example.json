{
  "local_host": "127.0.0.1",
  "local_port": 1080,
  "remote_port": 443,
  "sni": "www.cloudflare.com",
  "sni_list": [
    "www.cloudflare.com",
    "dash.cloudflare.com",
    "api.cloudflare.com",
    "blog.cloudflare.com",
    "developers.cloudflare.com",
    "cloudflare.com",
    "ssl.cloudflare.com"
  ],
  "pool_size": 5,
  "max_retries": 5,
  "connect_timeout": 10,
  "read_timeout": 300,
  "write_timeout": 30,
  "buffer_size": 32768,
  "tcp_nodelay": true,
  "keepalive": true,
  "keepalive_idle": 60,
  "keepalive_interval": 10,
  "keepalive_count": 5,
  "tls_version": "1.3",
  "verify_ssl": true,
  "alpn": ["h2", "http/1.1"],
  "health_check_interval": 30,
  "health_check_timeout": 5,
  "circuit_breaker_threshold": 3,
  "circuit_breaker_window": 60,
  "circuit_breaker_cooldown": 300,
  "verbose": 0,
  "bypass_method": "wrong_seq",
  "connection_mode": "on_demand"
}